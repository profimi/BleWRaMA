<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header ── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP32-C6 BLE Beacon"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Supermini Ranging Controller"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ── Connection Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONNECTION"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <ImageView
                        android:id="@+id/connectionStatusDot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_dot_gray"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/tvConnectionStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Disconnected"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <ProgressBar
                        android:id="@+id/scanProgress"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:indeterminateTint="@color/accent_blue"
                        android:visibility="gone" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnScan"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Connect"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/accent_blue"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Beacon State Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BEACON STATE"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingBottom="8dp" />

                <!-- Large status pill -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/beaconStatusIndicator"
                    android:background="@drawable/bg_status_idle"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvBeaconState"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IDLE"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                </LinearLayout>

                <!-- Control buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <!-- Ranging mode label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RANGING MODE"
                            android:textColor="@color/text_primary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:paddingBottom="6dp" />

                        <!-- ✅ FTM / CSI toggle -->
                        <!--
                                        <com.google.android.material.switchmaterial.SwitchMaterial
                                            android:id="@+id/switchMode"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="FTM / CSI"
                                            android:checked="true"/>
                        -->
                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/rangingModeToggle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:singleSelection="true"
                            app:selectionRequired="true"
                            app:checkedButton="@id/btnFtm">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnFtm"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FTM" />
<!--
                                app:backgroundTint="@color/toggle_button_bg"
                                android:textColor="@color/toggle_button_text"
-->

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnCsi"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CSI" />

                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>

                        <Button
                            android:id="@+id/btnStartMeasurement"
                            android:layout_width="0dp"
                            android:layout_height="68dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:backgroundTint="@color/accent_green"
                            android:enabled="false"
                            android:text="▶  Start"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnStopMeasurement"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="■  Stop"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/accent_red"
                    android:enabled="false"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Files Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STORED MEASUREMENTS"
                    android:textColor="@color/accent_blue"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tvFileList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No measurement files stored."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:paddingBottom="12dp" />

                <!-- Row 1: Delete + Plot -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="6dp">

                    <Button
                        android:id="@+id/btnDeleteLastFile"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="🗑 Last"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/accent_orange"
                        android:enabled="false" />

                    <Button
                        android:id="@+id/btnDeleteAllFiles"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="🗑 All"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/accent_red"
                        android:enabled="false" />

                    <Button
                        android:id="@+id/btnPlot"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="📈 Plot"
                        android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:backgroundTint="@color/accent_blue"
                        android:enabled="false" />
                </LinearLayout>

                <!-- Row 2: Export CSV (full width) -->
                <Button
                    android:id="@+id/btnExportCsv"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="⬆ Export Last as CSV"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:backgroundTint="@color/accent_green"
                    android:enabled="false" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Log Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Log header row: label + hint -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="EVENT LOG"
                        android:textColor="@color/accent_blue"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="long-press to copy"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:text=""
                    android:textColor="@color/log_text"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@color/log_bg"
                    android:padding="8dp"
                    android:longClickable="true" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
